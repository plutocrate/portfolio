# EmailJS credentials — get them at https://www.emailjs.com
# 1. Create a free account
# 2. Add an Email Service (Gmail/Outlook) → copy Service ID
# 3. Create an Email Template with variables: from_name, from_email, message, to_email → copy Template ID
# 4. Go to Account → Public Key → copy it
VITE_EMAILJS_SERVICE=service_XXXXXXX
VITE_EMAILJS_TEMPLATE=template_XXXXXXX
VITE_EMAILJS_KEY=your_public_key_here
